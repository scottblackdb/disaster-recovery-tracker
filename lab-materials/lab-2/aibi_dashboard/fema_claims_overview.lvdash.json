{
  "datasets": [
    {
      "name": "claims_summary",
      "displayName": "Claims Summary",
      "queryLines": [
        "SELECT ",
        "  COUNT(*) AS total_claims, ",
        "  SUM(estimated_cost) AS total_estimated, ",
        "  SUM(COALESCE(approved_amount, 0)) AS total_approved, ",
        "  AVG(ai_confidence_score) AS avg_confidence, ",
        "  COUNT(CASE WHEN status = 'approved' THEN 1 END) AS approved_claims, ",
        "  COUNT(CASE WHEN status = 'submitted' THEN 1 END) AS submitted_claims, ",
        "  COUNT(CASE WHEN status = 'ai_processed' THEN 1 END) AS ai_processed_claims ",
        "FROM fema_claims_workshop_catalog.public.claims"
      ]
    },
    {
      "name": "claims_by_status",
      "displayName": "Claims by Status",
      "queryLines": [
        "SELECT ",
        "  status, ",
        "  COUNT(*) AS claim_count, ",
        "  SUM(estimated_cost) AS total_estimated, ",
        "  SUM(COALESCE(approved_amount, 0)) AS total_approved ",
        "FROM fema_claims_workshop_catalog.public.claims ",
        "GROUP BY status ",
        "ORDER BY claim_count DESC"
      ]
    },
    {
      "name": "claims_by_category",
      "displayName": "Claims by FEMA Category",
      "queryLines": [
        "SELECT ",
        "  COALESCE(fc.code, 'N/A') AS category_code, ",
        "  COALESCE(fc.name, 'Uncategorized') AS category_name, ",
        "  COUNT(c.id) AS claim_count, ",
        "  SUM(c.estimated_cost) AS total_estimated, ",
        "  SUM(COALESCE(c.approved_amount, 0)) AS total_approved ",
        "FROM fema_claims_workshop_catalog.public.claims c ",
        "LEFT JOIN fema_claims_workshop_catalog.public.fema_categories fc ",
        "  ON c.fema_category_id = fc.id ",
        "GROUP BY COALESCE(fc.code, 'N/A'), COALESCE(fc.name, 'Uncategorized') ",
        "ORDER BY claim_count DESC"
      ]
    },
    {
      "name": "claims_by_county",
      "displayName": "Claims by County",
      "queryLines": [
        "SELECT ",
        "  COALESCE(county, 'Unknown') AS county, ",
        "  COUNT(*) AS claim_count, ",
        "  SUM(estimated_cost) AS total_estimated, ",
        "  SUM(COALESCE(approved_amount, 0)) AS total_approved ",
        "FROM fema_claims_workshop_catalog.public.claims ",
        "GROUP BY COALESCE(county, 'Unknown') ",
        "ORDER BY total_estimated DESC"
      ]
    },
    {
      "name": "claims_by_incident",
      "displayName": "Claims by Incident",
      "queryLines": [
        "SELECT ",
        "  COALESCE(incident_name, 'Unspecified') AS incident_name, ",
        "  COUNT(*) AS claim_count, ",
        "  SUM(estimated_cost) AS total_estimated, ",
        "  SUM(COALESCE(approved_amount, 0)) AS total_approved ",
        "FROM fema_claims_workshop_catalog.public.claims ",
        "GROUP BY COALESCE(incident_name, 'Unspecified') ",
        "ORDER BY total_estimated DESC"
      ]
    },
    {
      "name": "claims_over_time",
      "displayName": "Claims Over Time",
      "queryLines": [
        "SELECT ",
        "  DATE_TRUNC('DAY', submitted_at) AS submission_date, ",
        "  COUNT(*) AS claim_count, ",
        "  SUM(estimated_cost) AS total_estimated ",
        "FROM fema_claims_workshop_catalog.public.claims ",
        "GROUP BY DATE_TRUNC('DAY', submitted_at) ",
        "ORDER BY submission_date"
      ]
    },
    {
      "name": "claims_detail",
      "displayName": "Claims Detail",
      "queryLines": [
        "SELECT ",
        "  c.id, ",
        "  c.incident_name, ",
        "  c.county, ",
        "  c.applicant_name, ",
        "  COALESCE(fc.name, 'Uncategorized') AS category_name, ",
        "  c.status, ",
        "  c.estimated_cost, ",
        "  COALESCE(c.approved_amount, 0) AS approved_amount, ",
        "  c.ai_confidence_score, ",
        "  c.submitted_by, ",
        "  c.submitted_at ",
        "FROM fema_claims_workshop_catalog.public.claims c ",
        "LEFT JOIN fema_claims_workshop_catalog.public.fema_categories fc ",
        "  ON c.fema_category_id = fc.id ",
        "ORDER BY c.submitted_at DESC"
      ]
    },
    {
      "name": "documents_summary",
      "displayName": "Documents Summary",
      "queryLines": [
        "SELECT ",
        "  COUNT(*) AS total_documents, ",
        "  COUNT(DISTINCT claim_id) AS claims_with_docs, ",
        "  SUM(file_size) / 1024.0 / 1024.0 AS total_size_mb, ",
        "  AVG(ai_extracted_cost) AS avg_extracted_cost ",
        "FROM fema_claims_workshop_catalog.public.documents"
      ]
    },
    {
      "name": "documents_by_type",
      "displayName": "Documents by Type",
      "queryLines": [
        "SELECT ",
        "  file_type, ",
        "  COUNT(*) AS doc_count, ",
        "  SUM(COALESCE(ai_extracted_cost, 0)) AS total_extracted_cost ",
        "FROM fema_claims_workshop_catalog.public.documents ",
        "GROUP BY file_type ",
        "ORDER BY doc_count DESC"
      ]
    },
    {
      "name": "status_history",
      "displayName": "Recent Status Changes",
      "queryLines": [
        "SELECT ",
        "  h.claim_id, ",
        "  COALESCE(h.old_status, 'new') AS old_status, ",
        "  h.new_status, ",
        "  h.changed_by, ",
        "  h.changed_at, ",
        "  h.notes ",
        "FROM fema_claims_workshop_catalog.public.claim_status_history h ",
        "ORDER BY h.changed_at DESC ",
        "LIMIT 25"
      ]
    },
    {
      "name": "claims_forecast",
      "displayName": "Total Claims Forecast",
      "queryLines": [
        "WITH daily AS ( ",
        "  SELECT DATE_TRUNC('DAY', submitted_at) AS submission_date, ",
        "         CAST(COUNT(*) AS DOUBLE) AS claim_count ",
        "  FROM fema_claims_workshop_catalog.public.claims ",
        "  WHERE submitted_at IS NOT NULL ",
        "  GROUP BY DATE_TRUNC('DAY', submitted_at) ",
        "), ",
        "fcst AS ( ",
        "  SELECT * FROM AI_FORECAST( ",
        "    TABLE(daily), ",
        "    horizon => DATE_ADD(CURRENT_DATE(), 30), ",
        "    time_col => 'submission_date', ",
        "    value_col => 'claim_count' ",
        "  ) ",
        ") ",
        "SELECT ",
        "  submission_date, ",
        "  claim_count AS actual_claims, ",
        "  CAST(NULL AS DOUBLE) AS forecast_claims, ",
        "  CAST(NULL AS DOUBLE) AS forecast_upper, ",
        "  CAST(NULL AS DOUBLE) AS forecast_lower ",
        "FROM daily ",
        "UNION ALL ",
        "SELECT ",
        "  submission_date, ",
        "  CAST(NULL AS DOUBLE) AS actual_claims, ",
        "  claim_count_forecast AS forecast_claims, ",
        "  claim_count_upper AS forecast_upper, ",
        "  claim_count_lower AS forecast_lower ",
        "FROM fcst ",
        "ORDER BY submission_date"
      ]
    },
    {
      "name": "amounts_forecast",
      "displayName": "Claim Amounts Forecast",
      "queryLines": [
        "WITH daily AS ( ",
        "  SELECT DATE_TRUNC('DAY', submitted_at) AS submission_date, ",
        "         CAST(SUM(estimated_cost) AS DOUBLE) AS total_estimated ",
        "  FROM fema_claims_workshop_catalog.public.claims ",
        "  WHERE submitted_at IS NOT NULL ",
        "  GROUP BY DATE_TRUNC('DAY', submitted_at) ",
        "), ",
        "fcst AS ( ",
        "  SELECT * FROM AI_FORECAST( ",
        "    TABLE(daily), ",
        "    horizon => DATE_ADD(CURRENT_DATE(), 30), ",
        "    time_col => 'submission_date', ",
        "    value_col => 'total_estimated' ",
        "  ) ",
        ") ",
        "SELECT ",
        "  submission_date, ",
        "  total_estimated AS actual_amount, ",
        "  CAST(NULL AS DOUBLE) AS forecast_amount, ",
        "  CAST(NULL AS DOUBLE) AS forecast_upper, ",
        "  CAST(NULL AS DOUBLE) AS forecast_lower ",
        "FROM daily ",
        "UNION ALL ",
        "SELECT ",
        "  submission_date, ",
        "  CAST(NULL AS DOUBLE) AS actual_amount, ",
        "  total_estimated_forecast AS forecast_amount, ",
        "  total_estimated_upper AS forecast_upper, ",
        "  total_estimated_lower AS forecast_lower ",
        "FROM fcst ",
        "ORDER BY submission_date"
      ]
    }
  ],
